{
  "$schema": "../../schemas/witshift.config.schema.json",
  "version": 1,
  "entry": "src/server.ts",
  "build": {
    "package": "witshift:weather",
    "world": "mcp-tools",
    "timeoutMs": 180000
  },
  "policy": {
    "network": { "allow": [] },
    "storage": { "read": [], "write": [] }
  },
  "verification": {
    "originalAdapter": "verify/original.mjs",
    "componentAdapter": "verify/component.mjs",
    "evidenceLevel": "test-only"
  }
}
